# Database
DATABASE_URL=postgresql+asyncpg://toxzone:toxzone_pass@localhost:5432/toxzone
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=toxzone
DATABASE_USER=toxzone
DATABASE_PASSWORD=toxzone_pass

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
DEBUG=true

# Security
SECRET_KEY=change_this_in_production_random_string_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

